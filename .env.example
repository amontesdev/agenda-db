# ─── LOCAL (desarrollo) ───────────────────────────────────────
# Con estas vars la app usa un archivo SQLite local (local.db)
# No necesitas nada más para correr con `npm run dev`
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ─── PRODUCCIÓN en Vercel (Turso) ─────────────────────────────
# 1. Crea cuenta gratis en https://turso.tech
# 2. Crea una base de datos: turso db create agenda-db
# 3. Obtén la URL:   turso db show agenda-db --url
# 4. Obtén el token: turso db tokens create agenda-db
# 5. Agrega ambas vars en Vercel → Settings → Environment Variables
#
# TURSO_DATABASE_URL=libsql://agenda-db-<tu-usuario>.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# ─── FIREBASE AUTH (Google Identity Platform) ────────────────
# Client config (segura pero puede estar en public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Admin config (SECRETO — solo para APIs del servidor)
# Opción 1: Credential completo en base64 (recomendado para Vercel)
# FIREBASE_ADMIN_CREDENTIALS_B64=eyJ...

# Opción 2: Credenciales separadas
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# Dominio permitido para emails (opcional)
# ALLOW_ANY_EMAIL=false
