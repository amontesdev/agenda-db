# ─── LOCAL (desarrollo) ───────────────────────────────────────
# Con estas vars la app usa un archivo SQLite local (local.db)
# No necesitas nada más para correr con `npm run dev`
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ─── PRODUCCIÓN en Vercel (Turso) ─────────────────────────────
# 1. Crea cuenta gratis en https://turso.tech
# 2. Crea una base de datos: turso db create agenda-db
# 3. Obtén la URL:   turso db show agenda-db --url
# 4. Obtén el token: turso db tokens create agenda-db
# 5. Agrega ambas vars en Vercel → Settings → Environment Variables
#
# TURSO_DATABASE_URL=libsql://agenda-db-<tu-usuario>.turso.io
# TURSO_AUTH_TOKEN=eyJ...
